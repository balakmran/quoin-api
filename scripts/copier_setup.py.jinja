"""
    readme_path.write_text(content, encoding="utf-8")
    print("Wrote clean README.md")


def clean_index() -> None:
    """Replace the marketing home page with a minimal starter page."""
    index_path = BASE_DIR / "docs" / "index.md"
    if not index_path.exists():
        return
    content = f"""---
title: Home
---

# {PROJECT_NAME}

{DESCRIPTION}

New here? Start with the
[Getting Started guide](guides/getting-started.md).
"""
    index_path.write_text(content, encoding="utf-8")
    print("Wrote minimal docs/index.md")


def clean_zensical() -> None:
    """Trim the docs site config: nav, home JS, and personal social links."""
    zensical_path = BASE_DIR / "zensical.toml"
    if not zensical_path.exists():
        return
    content = zensical_path.read_text(encoding="utf-8")

    # Surgically drop only the nav entries for the pages removed above,
    # leaving the rest of the (source-controlled) nav untouched so it can't
    # drift from zensical.toml as guides/sections are added over time.
    # [{] / [}] match a literal brace defensively: should this pattern ever be
    # edited so two braces sit adjacent, a bare "{{"/"}}" would form a Jinja
    # token in this .jinja template. As written there is no adjacency, so the
    # class form is precautionary.
    removed_nav_pages = (
        "docs.md",
        "architecture/decision-log.md",
        "project/roadmap.md",
    )
    for page in removed_nav_pages:
        content = re.sub(
            r'^[ \t]*[{][ \t]*"[^"]+"[ \t]*=[ \t]*"'
            + re.escape(page)
            + r'"[ \t]*[}],\n',
            "",
            content,
            flags=re.MULTILINE,
        )

    # Drop the custom home-page JavaScript include.
    content = re.sub(
        r'extra_javascript = \[\n    "javascripts/home\.js",\n\]\n',
        "",
        content,
    )

    # Drop personal (X / LinkedIn) social links; keep the GitHub one.
    for brand in ("x-twitter", "linkedin"):
        content = re.sub(
            r'\n\n\[\[project\.extra\.social\]\]\n'
            rf'icon = "fontawesome/brands/{brand}"\nlink = "[^"]*"',
            "",
            content,
        )

    # Fail loudly rather than silently leaking the author's personal handles
    # if the social-link block above is ever reformatted past these patterns.
    leaked = [d for d in ("x.com", "x-twitter", "linkedin") if d in content]
    if leaked:
        raise RuntimeError(
            f"zensical.toml still references personal socials {leaked}; "
            "the social-link removal in clean_zensical() needs updating."
        )

    zensical_path.write_text(content, encoding="utf-8")
    print("Trimmed zensical.toml")


def strip_removed_links() -> None:
    """Remove cross-references to docs pages that were dropped."""
    overview_path = BASE_DIR / "docs" / "architecture" / "overview.md"
    if not overview_path.exists():
        return
    content = overview_path.read_text(encoding="utf-8")
    content = re.sub(
        r"- \[Decision Log\]\(decision-log\.md\)[^\n]*\n",
        "",
        content,
    )
    overview_path.write_text(content, encoding="utf-8")
    print("Stripped dropped-page links from architecture/overview.md")


def prune_sync_docs() -> None:
    """Drop the ROADMAP entry from the docs sync script."""
    sync_path = BASE_DIR / "scripts" / "sync_docs.py"
    if not sync_path.exists():
        return
    content = sync_path.read_text(encoding="utf-8")
    content = re.sub(
        r'        \(root / "ROADMAP\.md", docs_project / "roadmap\.md", '
        r"False\),\n",
        "",
        content,
    )
    sync_path.write_text(content, encoding="utf-8")
    print("Pruned ROADMAP from scripts/sync_docs.py")


if __name__ == "__main__":
    print(f"Running post-generation setup for {PROJECT_NAME}...")
    run_replacements()
    write_clean_changelog()
    reset_readme()
    clean_index()
    clean_zensical()
    strip_removed_links()
    prune_sync_docs()

    # Self-destruct copier files from the generated project
    try:
        os.remove(__file__)
        copier_yml = BASE_DIR / "copier.yml"
        if copier_yml.exists():
            os.remove(copier_yml)
    except Exception as e:
        print(f"Warning: Could not remove setup files: {e}")

    print("Setup complete! 🎉")
