import os
import re
from pathlib import Path

# --- Variables injected by Copier ---
PROJECT_NAME = "{{ project_name }}"
PROJECT_SLUG = "{{ project_slug }}"
ENV_PREFIX = "{{ env_prefix }}"
DESCRIPTION = "{{ description }}"
LONG_DESCRIPTION = "{{ long_description }}"
AUTHOR_NAME = "{{ author_name }}"
AUTHOR_EMAIL = "{{ author_email }}"
GITHUB_USERNAME = "{{ github_username }}"
GOOGLE_ANALYTICS_ID = "{{ google_analytics_id }}"

# --- Constants for Replacement ---
BASE_DIR = Path.cwd()

IGNORE_PATHS = {
    ".git",
    ".venv",
    "__pycache__",
    "site",
    ".pytest_cache",
    ".ruff_cache",
    ".coverage",
    "htmlcov",
    ".idea",
    ".vscode",
    "uv.lock",
}

IGNORE_EXTENSIONS = {
    ".pyc", ".pyo", ".pyd", ".so", ".dll", ".dylib",
    ".png", ".jpg", ".jpeg", ".gif", ".ico", ".svg", ".webp",
    ".mp4", ".mov", ".avi", ".webm",
    ".sqlite", ".db", ".pdf"
}


def process_file(file_path: Path) -> None:
    """Process a single file and apply all substitutions."""
    try:
        content = file_path.read_text(encoding="utf-8")
    except UnicodeDecodeError:
        return  # Skip binary or non-utf-8 files

    original_content = content
    name = file_path.name

    # 1. File-specific replacements. These are scoped by filename because the
    # patterns are deliberately loose (e.g. a bare `email = "..."`); applied
    # globally they would corrupt unrelated files such as test fixtures.
    if name == "metadata.py":
        # APP_DESCRIPTION is a single-line string literal.
        content = re.sub(
            r'APP_DESCRIPTION\s*=\s*"[^"]*"',
            f'APP_DESCRIPTION = "{DESCRIPTION}"',
            content,
        )
        # APP_LONG_DESCRIPTION is a triple-quoted block.
        content = re.sub(
            r'APP_LONG_DESCRIPTION\s*=\s*"""[\s\S]*?"""',
            f'APP_LONG_DESCRIPTION = """\n{LONG_DESCRIPTION}\n"""',
            content,
        )
    elif name == "pyproject.toml":
        # Project description field.
        content = re.sub(
            r'description\s*=\s*"The Foundation.*?"',
            f'description = "{DESCRIPTION}"',
            content,
            flags=re.DOTALL,
        )
        # authors[].email — only the project metadata, never fixture data.
        content = re.sub(
            r'email\s*=\s*"[^"]*"',
            f'email = "{AUTHOR_EMAIL}"',
            content,
        )
    elif name == "zensical.toml":
        # Google Analytics property value. Always keep the section; set an
        # empty string when no ID is provided.
        content = re.sub(
            r'(property\s*=\s*")[^"]*(")',
            rf'\g<1>{GOOGLE_ANALYTICS_ID}\g<2>',
            content,
        )

    # 2. Documentation URL (appears in pyproject.toml and zensical.toml).
    content = content.replace(
        "https://balakmran.github.io/quoin-api/",
        f"https://{GITHUB_USERNAME}.github.io/{PROJECT_SLUG}/",
    )

    # 3. General string replacements applied to every file. Order matters:
    # more specific keys must precede the keys they contain. In particular the
    # two urn:* keys come before "quoin_": the special-cased
    # urn:quoin:error:quoin_error maps to app_error (the snake_case of the
    # QuoinError base, which is renamed AppError above) rather than letting the
    # generic "quoin_" -> prefix rule turn it into "<prefix>_error".
    replacements = {
        "QuoinAPI": PROJECT_NAME,
        "QuoinError": "AppError",
        "urn:quoin:error:quoin_error": f"urn:{PROJECT_SLUG}:error:app_error",
        "urn:quoin:error": f"urn:{PROJECT_SLUG}:error",
        "quoin-api": PROJECT_SLUG,
        "quoin_": f"{ENV_PREFIX.lower()}_",
        "QUOIN_": f"{ENV_PREFIX.upper()}_",
        "balakmran": GITHUB_USERNAME,
        "Balakumaran Manoharan": AUTHOR_NAME,
    }

    for old, new in replacements.items():
        content = content.replace(old, new)

    if original_content != content:
        file_path.write_text(content, encoding="utf-8")
        print(f"Updated {file_path.relative_to(BASE_DIR)}")


def write_clean_changelog() -> None:
    """Overwrite CHANGELOG.md with a clean starter template."""
    changelog_path = BASE_DIR / "CHANGELOG.md"
    content = f"""# Changelog

All notable changes to **{PROJECT_NAME}** will be documented in this file.

The format is based on [Keep a Changelog](https://keepachangelog.com/en/1.0.0/),
and this project adheres to
[Semantic Versioning](https://semver.org/spec/v2.0.0.html).

## [Unreleased]

[Unreleased]: https://github.com/{GITHUB_USERNAME}/{PROJECT_SLUG}/commits/main
"""
    changelog_path.write_text(content, encoding="utf-8")
    print("Wrote clean CHANGELOG.md")


def run_replacements() -> None:
    """Walk the generated project and apply all substitutions."""
    for root, dirs, files in os.walk(BASE_DIR):
        dirs[:] = [
            d for d in dirs
            if d not in IGNORE_PATHS and not d.endswith(".egg-info")
        ]
        for file_name in files:
            file_path = Path(root) / file_name
            if file_path.suffix in IGNORE_EXTENSIONS:
                continue
            # Skip this script and copier config (handled separately)
            if file_name in {"copier_setup.py", "copier.yml"}:
                continue
            # CHANGELOG and README are rewritten fresh - skip general pass
            if file_name in {"CHANGELOG.md", "README.md"}:
                continue
            process_file(file_path)


