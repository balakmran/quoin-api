# Application
# Environment: development, test, production
QUOIN_ENV=development
QUOIN_LOG_LEVEL=INFO
QUOIN_OTEL_ENABLED=True
# Header name used to propagate request IDs (e.g. X-Correlation-ID)
QUOIN_REQUEST_ID_HEADER=X-Request-ID
# Per-request wall-clock timeout in seconds (<=0 disables the timeout)
QUOIN_REQUEST_TIMEOUT_SECONDS=30.0

# CORS — explicit allowlist; wildcards are rejected with allow_credentials
# in non-development environments
QUOIN_BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]
QUOIN_BACKEND_CORS_ALLOW_METHODS=["GET","POST","PUT","PATCH","DELETE","OPTIONS"]
QUOIN_BACKEND_CORS_ALLOW_HEADERS=["Authorization","Content-Type","X-Request-ID"]
QUOIN_BACKEND_CORS_ALLOW_CREDENTIALS=True

# Security response headers
QUOIN_SECURITY_HEADERS_ENABLED=True
# HSTS — browsers honour this only on HTTPS responses; set to 0 to disable
QUOIN_SECURITY_HSTS_MAX_AGE=31536000
QUOIN_SECURITY_HSTS_INCLUDE_SUBDOMAINS=True
QUOIN_SECURITY_HSTS_PRELOAD=False
QUOIN_SECURITY_CSP=default-src 'self'; style-src 'self' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' https://cdn.simpleicons.org; script-src 'self' 'unsafe-inline'; frame-ancestors 'none'; base-uri 'self'
QUOIN_SECURITY_REFERRER_POLICY=strict-origin-when-cross-origin
QUOIN_SECURITY_PERMISSIONS_POLICY=geolocation=(), camera=(), microphone=()

# Maximum request body size in bytes (<=0 disables the cap). Default: 1 MiB
QUOIN_MAX_REQUEST_BODY_BYTES=1048576

# Database
QUOIN_POSTGRES_DRIVER=postgresql+asyncpg
QUOIN_POSTGRES_HOST=localhost
QUOIN_POSTGRES_PORT=5432
QUOIN_POSTGRES_USER=postgres
QUOIN_POSTGRES_PASSWORD=postgres
QUOIN_POSTGRES_DB=app_db

# OAuth 2.0 / OIDC (app-to-app authentication)
# Point at your authorization server or the local mock (just oauth)
QUOIN_OAUTH_JWKS_URI=http://localhost:8080/default/jwks
QUOIN_OAUTH_ISSUER=http://localhost:8080/default
QUOIN_OAUTH_AUDIENCE=default
# JWT claim key that contains the caller's roles (default: roles)
# Production IdPs (Azure AD, Auth0, Keycloak): roles
# Local mock-oauth2-server: aud
QUOIN_OAUTH_ROLES_CLAIM=roles
